# ============================================================
#  FRONTEND .gitignore – Vite + React + TypeScript
# ============================================================

# ==================== Môi trường (SECURITY) ====================
.env
.env.*
!.env.example

# ==================== Dependencies ====================
node_modules/
.pnp
.pnp.js

# ==================== Build output ====================
dist/
dist-ssr/
build/
*.local

# ==================== Log ====================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==================== IDE & Editor ====================
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==================== Testing ====================
coverage/
.nyc_output/

# ==================== Cache ====================
.eslintcache
.stylelintcache
*.tsbuildinfo
