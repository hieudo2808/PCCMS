# ============================================================
#  BACKEND .gitignore – Spring Boot + Maven (Java)
# ============================================================

# ==================== Cấu hình ứng dụng (SECURITY) ====================
src/main/resources/application.yml
src/main/resources/application.yaml
src/main/resources/application.properties
src/main/resources/application-*.yml
src/main/resources/application-*.yaml
src/main/resources/application-*.properties

# ==================== Môi trường (SECURITY) ====================
.env
.env.*
!.env.example

# ==================== Maven build ====================
target/
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.jar
HELP.md

# ==================== Gradle build (phòng khi dùng) ====================
build/
!**/src/main/**/build/
!**/src/test/**/build/
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# ==================== IDE: Spring Tool Suite ====================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ==================== IDE: IntelliJ IDEA ====================
.idea/
*.iws
*.iml
*.ipr

# ==================== IDE: NetBeans ====================
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# ==================== IDE: VS Code ====================
.vscode/

# ==================== Hệ điều hành ====================
.DS_Store
Thumbs.db

# ==================== Log ====================
*.log
logs/
