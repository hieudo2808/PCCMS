server:
    port: 8080

spring:
    application:
        name: pccms
    datasource:
        url: jdbc:postgresql://localhost:5432/pccms
        username: pccms
        password: pccms
        driver-class-name: org.postgresql.Driver
    jpa:
        hibernate:
            ddl-auto: validate
        show-sql: true
        properties:
            hibernate:
                format_sql: true
    data:
        redis:
            host: localhost
            port: 6379
            password: redis-password
            ssl:
                enabled: false
    mail:
        host: smtp.gmail.com
        port: 587
        username: youremail@gmail.com
        password: your_password
        properties:
            mail:
                smtp:
                    auth: true
                    starttls:
                        enable: true
                        required: true

jwt:
    # Base64URL-encoded key >= 64 bytes (512 bits) for HS512. Generate a new secret for production.
    secret: ZXLx6CIS8StkPC2vmaA
    expiration: 600000
    refresh-expiration: 604800000

security:
    pepper: local-dev-pepper-change-me

app:
    cors:
        allowed-origins: http://localhost:5173

management:
    endpoints:
        web:
            exposure:
                include: health,info,metrics
    endpoint:
        health:
            show-details: when_authorized
    health:
        mail:
            enabled: false

logging:
    level:
        root: INFO
        com.astral.express: DEBUG
        org.springframework.security: INFO

pccms:
    mail:
        app-name: Pawluna
        team-name: Astral Team
        from: no-reply@pccms.local
    r2:
        account-id: ${R2_ACCOUNT_ID:}
        access-key-id: ${R2_ACCESS_KEY_ID:}
        secret-access-key: ${R2_SECRET_ACCESS_KEY:}
        bucket: ${R2_BUCKET:}
        public-base-url: ${R2_PUBLIC_BASE_URL:}
        cache-control: ${R2_CACHE_CONTROL:public,max-age=31536000,immutable}
