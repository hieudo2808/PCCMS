server:
    port: 8080

spring:
    application:
        name: pccms
    datasource:
        url: ${DB_URL:jdbc:postgresql://localhost:17284/pccms}
        username: ${DB_USERNAME:postgres}
        password: ${DB_PASSWORD:}
        driver-class-name: org.postgresql.Driver
    jpa:
        hibernate:
            ddl-auto: validate
        show-sql: true
        properties:
            hibernate:
                format_sql: true
    data:
        redis:
            host: localhost
            port: 6379
            password: ${REDIS_PASSWORD:}
            ssl:
                enabled: false
    mail:
        host: smtp.gmail.com
        port: 587
        username: ${SMTP_USERNAME:}
        password: ${SMTP_PASSWORD:}
        properties:
            mail:
                smtp:
                    auth: true
                    starttls:
                        enable: true
                        required: true

jwt:
    # Base64URL-encoded key >= 64 bytes (512 bits) for HS512. Generate a new secret for production.
    secret: ${JWT_SECRET:}
    expiration: 600000
    refresh-expiration: 604800000

security:
    pepper: ${SECURITY_PEPPER:}

app:
    cors:
        allowed-origins: http://localhost:5173
    auth:
        refresh-cookie-secure: false

management:
    endpoints:
        web:
            exposure:
                include: health,info,metrics
    endpoint:
        health:
            show-details: when_authorized
    health:
        mail:
            enabled: false

logging:
    level:
        root: INFO
        com.astral.express: DEBUG
        org.springframework.security: INFO

pccms:
    mail:
        app-name: Pawluna
        team-name: Astral Team
        from: no-reply@pccms.local
    r2:
        account-id: ${R2_ACCOUNT_ID:}
        access-key-id: ${R2_ACCESS_KEY_ID:}
        secret-access-key: ${R2_SECRET_ACCESS_KEY:}
        bucket: ${R2_BUCKET:}
        public-base-url: ${R2_PUBLIC_BASE_URL:}
        cache-control: ${R2_CACHE_CONTROL:public,max-age=31536000,immutable}
