server:
    port: 8080

spring:
    application:
        name: 
    datasource:
        url: jdbc:sqlserver://localhost:17288;database=CodeTrials;encrypt=true;trustServerCertificate=true
        username: 
        password: 
        driver-class-name: com.microsoft.sqlserver.jdbc.SQLServerDriver
    jpa:
        hibernate:
            ddl-auto: validate
            naming:
                physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
        show-sql: true
        properties:
            hibernate:
                format_sql: true
    data:
        redis:
            host: localhost
            port: 6379
            password: redis-password
            ssl:
                enabled: true
    mail:
        host: smtp.gmail.com
        port: 587
        username: youremail@gmail.com
        password: your_password
        properties:
            mail:
                smtp:
                    auth: true
                    starttls:
                        enable: true
                        required: true

jwt:
    secret: ${JWT_SECRET:replace-with-base64url-secret-at-least-64-bytes}
    expiration: 600000
    refresh-expiration: 604800000

security:
    pepper: your-pepper

app:
    cors:
        allowed-origins: http://localhost:5173

management:
    endpoints:
        web:
            exposure:
                include: health,info,metrics
    endpoint:
        health:
            show-details: when_authorized
    health:
        mail:
            enabled: false

logging:
    level:
        root: INFO
        com.astral.express: DEBUG
        org.springframework.security: INFO

pccms:
    seed:
        admin:
            enabled: ${PCCMS_SEED_ADMIN_ENABLED:false}
            reset-password: ${PCCMS_SEED_ADMIN_RESET_PASSWORD:false}
            email: ${PCCMS_SEED_ADMIN_EMAIL:}
            password: ${PCCMS_SEED_ADMIN_PASSWORD:}
            full-name: ${PCCMS_SEED_ADMIN_FULL_NAME:System Admin}
            role-code: ${PCCMS_SEED_ADMIN_ROLE_CODE:ADMIN}
    mail:
        app-name: Pawluna
        team-name: Astral Team
        from: no-reply@pccms.local
